# .env.example
# Copy to .env.local and fill in your values.
# Never commit .env.local to git.

# # Supabase — get these from your project's API settings [COMMENTED OUT - NO LONGER USING SUPABASE]
# EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Anthropic API key — only needed for local Edge Function testing.
# # In production this lives as a Supabase secret (never in the app bundle).
# # supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY=sk-ant-your-key-here
